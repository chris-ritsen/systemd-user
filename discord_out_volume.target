[Unit]
Description=Discord audio output with volume control
After=jackd.service
BindsTo=jackd.service
Conflicts=discord_out.target

Requires=jack_volume@discord_out.service
After=jack_volume@discord_out.service

Conflicts=jack_connection@discord_out.front\x2dleft\x2clinux_main_volume.in_1.target
Conflicts=jack_connection@discord_out.front\x2dright\x2clinux_main_volume.in_2.target

Requires=jack_connection@discord_out.front\x2dleft\x2cdiscord_out_volume.in_1.target
Requires=jack_connection@discord_out.front\x2dright\x2cdiscord_out_volume.in_2.target
Requires=jack_connection@discord_out_volume.out_1\x2clinux_main_volume.in_1.target
Requires=jack_connection@discord_out_volume.out_2\x2clinux_main_volume.in_2.target

Requires=jack_disconnection@discord_out.front\x2dleft\x2csystem.playback_1.target
Requires=jack_disconnection@discord_out.front\x2dright\x2csystem.playback_2.target

After=jack_connection@discord_out.front\x2dleft\x2cdiscord_out_volume.in_1.target
After=jack_connection@discord_out.front\x2dright\x2cdiscord_out_volume.in_2.target
After=jack_connection@discord_out_volume.out_1\x2clinux_main_volume.in_1.target
After=jack_connection@discord_out_volume.out_2\x2clinux_main_volume.in_2.target
After=jack_disconnection@discord_out.front\x2dleft\x2csystem.playback_1.target
After=jack_disconnection@discord_out.front\x2dright\x2csystem.playback_2.target
