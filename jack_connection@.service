[Unit]
After=jack-connection-manager.service
Requires=jack-connection-manager.service
BindsTo=jack.target
Description=Ensure JACK connection %I

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=%h/.local/bin/jack-connection manager --connect "%I"
ExecStop=%h/.local/bin/jack-connection manager --remove "%I"
