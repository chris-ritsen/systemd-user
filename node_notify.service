
[Unit]

StopWhenUnneeded = yes

# After = jackd.service
# Before = speakers.service
# PartOf = jackd.service

[Service]

Environment = DISPLAY=:0
Environment = DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus
NotifyAccess = all
Nice = 19
RemainAfterExit = yes
Restart = no
RestartSec = 1
StartLimitBurst = 0
TimeoutStartSec = 20s
TimeoutStopSec = 20s
Type = notify
Slice = audio.slice

ExecStart = /usr/bin/node %h/home-control/dbus/speakers.js

