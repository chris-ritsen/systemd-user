[Unit]

After = jackd.service
BindsTo = jackd.service

StopWhenUnneeded = no

[Service]

Environment = JACK_NO_START_SERVER=1
Environment = DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus
Environment = DISPLAY=:0
Nice = 19
NotifyAccess = all
RemainAfterExit = yes
Restart = always
RestartSec = 1
Slice = audio.slice
StartLimitBurst = 0
TimeoutStartSec = 20s
TimeoutStopSec = 20s
Type = notify

ExecStart = /usr/bin/node %h/home-control/dbus/discord.js
