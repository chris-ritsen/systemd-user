
[Unit]
Conflicts=shutdown.target
Description=Start scripted tmux session

[Service]
EnvironmentFile=/home/chris/.config/systemd/user/default_env
ExecStart=/usr/bin/zsh -c "/usr/bin/tmux -S /home/chris/.tmp/tmux/tmux-1000/%i -f /home/chris/.config/tmux/sessions/%i start-server"
ExecStop=/usr/bin/tmux -S /home/chris/.tmp/tmux/tmux-1000/%i kill-server
Restart=always
RestartSec=1
Type=forking
WorkingDirectory=/home/chris/

[Install]
WantedBy=default.target
DefaultInstance=admin

