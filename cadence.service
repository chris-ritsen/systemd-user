[Unit]

Description = Cadence — JACK configuration and monitoring GUI
Documentation=https://kx.studio/Applications:Cadence
Documentation=https://kx.studio/Applications:Cadence

After = jackd.service
BindsTo = jackd.service

StopWhenUnneeded = no

[Service]

Environment = JACK_NO_START_SERVER=1
Environment = DISPLAY=:0

ExecStart = /usr/bin/cadence

KillMode = process
Nice = 19
Restart=no
RestartSec=6
Slice = audio.slice
TimeoutStartSec = 2s
TimeoutStopSec = 2s

[Install]
WantedBy = default.target
