[Unit]

After = graphical.target
StopWhenUnneeded = yes
Description = Keyboard setup
Documentation = file://%h/.scripts/fixes/keyboard.zsh
Wants = keyboard-device.path
BindsTo = keyboard-device.path
PartOf = keyboard-device.path
ConditionPathExists = /dev/input/hhkb

[Service]

StartLimitInterval=2s
StartLimitBurst=5
ExecStart = /bin/zsh -c '~/.scripts/fixes/keyboard.zsh'
Type = oneshot
# RemainAfterExit = yes

[Install]

WantedBy = default.target
