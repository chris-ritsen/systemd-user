[Unit]
Description=Dante subscription: %i
Documentation=file://%h/bin/dante_device
After=dante-manager.service
Requires=dante-manager.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=%h/.local/bin/dante-device --mode manager "subscription:connect,%I"
ExecStop=%h/.local/bin/dante-device --mode manager "subscription:disconnect,%I"

StandardOutput=journal
StandardError=journal
SyslogIdentifier=dante-device-subscription-%I

[Install]
WantedBy=default.target
