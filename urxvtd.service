[Unit]

Description=Urxvt Terminal Daemon
BindsTo=graphical-session.target
PartOf=graphical-session.target
ConditionEnvironment=DISPLAY

[Service]

Environment=RXVT_SOCKET=%t/urxvtd-%H
ExecStart=/usr/bin/urxvtd -q -o -f
KillMode=process
Restart=always
RestartSec=1
TimeoutStartSec=10s
TimeoutStopSec=10s
Type=forking
Slice = urxvtd.slice
