
[Unit]

Description = Load X resources from ~/.Xresources
Documentation = man:xrdb(1)
RefuseManualStart = no
RefuseManualStop = no

[Service]

ExecStart = /usr/bin/xrdb -load %h/.Xresources
ExecStartPost = /usr/bin/xrdb -load %h/.Xresources 
RemainAfterExit = no
RestartSec = 2
Type = oneshot

[Install]

WantedBy = xmonad.target

