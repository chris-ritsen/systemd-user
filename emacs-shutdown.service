[Unit]
Description=Emacs Shutdown Tasks
Before=shutdown.target reboot.target halt.target poweroff.target
DefaultDependencies=no

[Service]
Type=oneshot
ExecStart=/usr/bin/emacsclient -a "" --eval "(progn (org-clock-out) (save-some-buffers t nil))" 1>/dev/null

[Install]
WantedBy=halt.target poweroff.target reboot.target
