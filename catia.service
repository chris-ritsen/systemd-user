[Unit]

Description=Catia jack patchbay

After = jackd.service
BindsTo = jackd.service
Requires = sound.target graphical-session.target

StopWhenUnneeded = no

[Service]

Environment = JACK_NO_START_SERVER=1
Nice = 19

ExecStart=/usr/bin/catia

KillMode=process
RestartSec=20
TimeoutStartSec=2s
TimeoutStopSec=2s
Slice = audio.slice

[Install]
WantedBy = default.target
