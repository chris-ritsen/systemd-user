[Unit]
Description=Rupert Neve Designs Satellite 5059 — summing mixer
Requires=outlet@1.service
After=outlet@1.service
BindsTo = outlet@1.service
PartOf=satellite-5059.target
StopWhenUnneeded=yes
RefuseManualStart=yes
RefuseManualStop=yes

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStop=/usr/bin/zsh -ic "echo 'Shutting down Satellite 5059...'"

TimeoutStartSec=40s
TimeoutStopSec=5s
RestartSec=5s
