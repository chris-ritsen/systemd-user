
[Unit]

Description = ecasound %i effects
Requires = jackd.service
Requires = mic_notify.service
After = mic_notify.service
BindsTo = outlet@7.service
BindsTo = outlet@3.service

[Service]

TimeoutStartSec = 50s
Environment = TERM=xterm
ExecStart = /usr/bin/zsh -ic "ecasound -G:jack,%i_effects -C -f:f32_le,1,48000 jack,,in -o jack,,out -a:1 -eadb:-1"
