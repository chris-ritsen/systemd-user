[Unit]
Description=Dante VR Room Output On (avio-aes3-1 → lx-dante stereo pair)

Conflicts=dante-vrroom-out-off.target

Wants=dante-device-subscription@avio-aes3-1\x2cvrroom:left\x2clx-dante\x2cvrroom:left.service
Wants=dante-device-subscription@avio-aes3-1\x2cvrroom:right\x2clx-dante\x2cvrroom:right.service

Conflicts=dante-device-disconnection@avio-aes3-1\x2cvrroom:left\x2clx-dante\x2cvrroom:left.service
Conflicts=dante-device-disconnection@avio-aes3-1\x2cvrroom:right\x2clx-dante\x2cvrroom:right.service

[Install]
WantedBy=default.target
