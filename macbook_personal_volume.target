[Unit]
Description=MacBook personal audio input with volume control
After=jackd.service
BindsTo=jackd.service
Conflicts=macbook_personal_direct.target

Requires=jack_volume@macbook_personal.service
After=jack_volume@macbook_personal.service

Conflicts=jack_connection@system.capture_11\x2cspeakers_bus_volume.in_1.target
Conflicts=jack_connection@system.capture_12\x2cspeakers_bus_volume.in_2.target
Conflicts=jack_connection@system.capture_11\x2clinux_main_volume.in_1.target
Conflicts=jack_connection@system.capture_12\x2clinux_main_volume.in_2.target

Requires=jack_connection@system.capture_11\x2cmacbook_personal_volume.in_1.target
Requires=jack_connection@system.capture_12\x2cmacbook_personal_volume.in_2.target
Requires=jack_connection@macbook_personal_volume.out_1\x2cspeakers_bus_volume.in_1.target
Requires=jack_connection@macbook_personal_volume.out_2\x2cspeakers_bus_volume.in_2.target
Requires=jack_connection@macbook_personal_volume.out_1\x2clinux_main_volume.in_1.target
Requires=jack_connection@macbook_personal_volume.out_2\x2clinux_main_volume.in_2.target

After=jack_connection@system.capture_11\x2cmacbook_personal_volume.in_1.target
After=jack_connection@system.capture_12\x2cmacbook_personal_volume.in_2.target
After=jack_connection@macbook_personal_volume.out_1\x2cspeakers_bus_volume.in_1.target
After=jack_connection@macbook_personal_volume.out_2\x2cspeakers_bus_volume.in_2.target
After=jack_connection@macbook_personal_volume.out_1\x2clinux_main_volume.in_1.target
After=jack_connection@macbook_personal_volume.out_2\x2clinux_main_volume.in_2.target
