[Unit]

AssertFileIsExecutable=%h/.xmonad/xmonad-x86_64-linux
Description = XMonad recompile
Documentation=man:xmonad(1) file://%h/.xmonad/xmonad.hs
RefuseManualStart = no
RefuseManualStop = no
Wants = xmonad.path

[Service]

ExecStart = /usr/bin/xmonad --recompile
ExecStartPost = /usr/bin/xmonad --restart
RemainAfterExit = no
RestartSec = 2
Type = oneshot

[Install]

WantedBy = graphical-session-pre.target
