
[Unit]

Before = outlet@8.service
Before = outlet@3.service
PartOf = microphone.service
Wants = microphone.service

StopWhenUnneeded = no

[Service]

Environment = DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus
Environment = DISPLAY=:0
Nice = 19
NotifyAccess = all
RemainAfterExit = yes
Restart = no
RestartSec = 1
Slice = audio.slice
StartLimitBurst = 0
TimeoutStartSec = 20s
TimeoutStopSec = 20s
Type = notify

ExecStart = /usr/bin/node %h/home-control/dbus/mic_out.js
