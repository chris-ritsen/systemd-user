[Unit]
Description=Rupert Neve Designs Portico 5043 Right — stereo compressor
Requires=outlet@7.service
After=outlet@7.service
BindsTo=outlet@7.service
PartOf=portico-5043-right.target
StopWhenUnneeded=yes
RefuseManualStart=yes
RefuseManualStop=yes

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStop=/usr/bin/zsh -ic "echo 'Shutting down Portico 5043 Right...'"

TimeoutStartSec=40s
TimeoutStopSec=5s
RestartSec=5s
