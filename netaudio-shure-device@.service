[Unit]
Description=Shure device enforcement: %i
After=netaudio.service
Requires=netaudio.service
PartOf=netaudio.service

[Service]
Type=notify
ExecStart=%h/.local/bin/netaudio-enforce shure-device %I
NotifyAccess=all
TimeoutStartSec=15
TimeoutStopSec=5

StandardOutput=journal
StandardError=journal
SyslogIdentifier=netaudio-shure-device-%I

[Install]
WantedBy=default.target
