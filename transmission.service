
[Unit]
Description=Transmission BitTorrent
Documentation=man:transmission-daemon(1)
ConditionPathExists=/sys/class/net/wgnord/
# Wants = transmission_vpn.path
# Conflicts = vpn_transmission_check.service

[Service]
ExecReload=/bin/kill -s HUP $MAINPID
ExecStart=/usr/bin/transmission-daemon -f --log-error
TimeoutStopSec=1
Restart=no
Type=notify

[Install]
WantedBy=multi-user.target
